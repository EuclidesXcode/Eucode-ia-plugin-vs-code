{
    "compilerOptions": {
        "module": "node16",
        "target": "es2020",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node16",
        "types": ["node"],
        "rootDir": "./src",
        "outDir": "./dist"
    },
    "include": ["src/**/*.ts"]
}
